<idea-plugin package="org.kkkzbh.cph" url="https://github.com/kkkzbh/CPH">
    <id>org.kkkzbh.cph</id>
    <name>CPH Target Runner</name>
    <vendor email="kkkzbh@vip.qq.com" url="https://github.com/kkkzbh/CPH">kkkzbh</vendor>
    <description><![CDATA[
        A CLion competitive-programming tool that manages sample cases for each target or single file, lets you run and compare outputs quickly, configure compiler options and shortcuts, and submit solutions to Codeforces from the active editor file.
    ]]></description>
    <change-notes><![CDATA[
        <h3>1.2.5</h3>
        <ul>
          <li>修复 Windows 纯单文件模式下 C/C++ File 样例运行可能找不到可执行文件的问题。</li>
          <li>按平台可执行后缀解析 CLion 返回的运行文件，支持 .exe 等产物路径。</li>
          <li>改进单文件构建重试清理逻辑，并补充运行路径解析回归测试。</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.clion</depends>

    <dependencies>
        <module name="intellij.clion.runFile" />
    </dependencies>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="org.kkkzbh.cph.CphStateService" />
        <projectService serviceImplementation="org.kkkzbh.cph.CphCppFileBuildCache" />
        <projectService serviceImplementation="org.kkkzbh.cph.CphShortcutDispatcher" />
        <projectService serviceImplementation="org.kkkzbh.cph.CphSingleFileModeService" />
        <projectService serviceImplementation="org.kkkzbh.cph.CphGccPchService" />
        <projectService serviceImplementation="org.kkkzbh.cph.CphBuildOutputService" />
        <applicationService serviceImplementation="org.kkkzbh.cph.CphPluginSettings" />
        <applicationService serviceImplementation="org.kkkzbh.cph.CphThemeAssetService" />
        <applicationService serviceImplementation="org.kkkzbh.cph.CphShortcutSettings" />
        <applicationService serviceImplementation="org.kkkzbh.cph.server.CphImportSettings" />
        <applicationService serviceImplementation="org.kkkzbh.cph.server.CphCompetitiveCompanionServer" />
        <applicationService serviceImplementation="org.kkkzbh.cph.submit.CphActiveTabService" />
        <projectService serviceImplementation="org.kkkzbh.cph.submit.CphSubmitOrchestrator" />
        <applicationConfigurable parentId="tools"
                                 id="org.kkkzbh.cph.settings"
                                 displayName="CPH Target Runner"
                                 instance="org.kkkzbh.cph.server.CphImportSettingsConfigurable" />
        <postStartupActivity implementation="org.kkkzbh.cph.server.CphCompetitiveCompanionStarter" />
        <notificationGroup id="CPH Target Runner" displayType="BALLOON" />
        <notificationGroup id="CPH Submit" displayType="BALLOON" />
        <toolWindow id="CPH"
                    anchor="right"
                    icon="/icons/cphToolWindow.svg"
                    factoryClass="org.kkkzbh.cph.CphToolWindowFactory"
                    canCloseContents="false" />
    </extensions>

    <actions>
        <action id="cph.submit"
                class="org.kkkzbh.cph.submit.CphSubmitAction"
                text="CPH: Submit Current File to Codeforces"
                description="Submit the current editor file to the Codeforces problem currently open in your browser tab." />
    </actions>
</idea-plugin>
